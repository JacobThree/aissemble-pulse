# Copy to `.env` for local development (never commit `.env`).
# No production secrets: dev DB passwords come from `deploy/sql/init-timescale.sql` + Compose.
# Compose maps Postgres to host port 5433 — see README.

# --- Timescale (read/write + read-only Streamlit) ---
DATABASE_URL=postgresql://city_pulse:city_pulse@localhost:5433/city_pulse
DATABASE_READONLY_URL=postgresql://city_pulse_reader:city_pulse_reader@localhost:5433/city_pulse

# --- Redis (frame queue + dashboard ops) ---
REDIS_URL=redis://localhost:6379/0

# --- MLServer HTTP (OIP REST) ---
YOLO_ENDPOINT=http://localhost:8080
SUMY_ENDPOINT=http://localhost:8090
# SUMY_MODEL_NAME=sumy
# SUMY_HTTP_TIMEOUT_SECONDS=120

# --- Vision worker ---
# VISION_MODEL_NAME=yolov8
# VISION_VEHICLE_LABELS=car,truck,bus,motorcycle
# VISION_MIN_CONFIDENCE=0.25
# VISION_HTTP_TIMEOUT_SECONDS=120
# VISION_BRPOP_TIMEOUT_SECONDS=5
# VISION_DB_POOL_MAX=4

# --- Daily brief job ---
# DAILY_BRIEF_DB_POOL_MAX=2

# --- Streamlit dashboard ---
# DASHBOARD_CHART_REFRESH_SECONDS=5

# --- Ingest (public HLS only; see README legal + GIS notes) ---
# Dashboard shows a live preview when INGEST_M3U8_URL is set (restart Streamlit after changes).
# INGEST_M3U8_URL=https://strmr5.sha.maryland.gov/rtplive/<camera_id>/playlist.m3u8
# INGEST_CAMERA_KEY=i695-park-heights
# INGEST_SAMPLE_INTERVAL_SECONDS=7.5
# INGEST_QUEUE_KEY=city_pulse:frames
# INGEST_MAX_QUEUE_LENGTH=64
# INGEST_JPEG_QUALITY=85
# INGEST_BACKOFF_INITIAL_SECONDS=1.0
# INGEST_BACKOFF_MAX_SECONDS=60.0
# INGEST_BACKOFF_MULTIPLIER=2.0
# Ingest success heartbeat (ISO time) for Streamlit ops — empty value disables
# INGEST_HEARTBEAT_KEY=city_pulse:ingest:last_success_at
